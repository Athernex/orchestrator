# Public-safe local defaults. Copy to .env for private overrides.
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
LOCALSTACK_ENDPOINT=http://127.0.0.1:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Keep real Paperclip credentials outside git.
PAPERCLIP_ENDPOINT=http://127.0.0.1:3100
PAPERCLIP_API_KEY=replace-me-locally
PAPERCLIP_HOST=0.0.0.0
PAPERCLIP_PORT=3100

# Local Codex scheduler bridge settings. This bridge is not upstream Paperclip.
CODEX_SCHEDULER_HOST=0.0.0.0
CODEX_SCHEDULER_PORT=8090
CODEX_SCHEDULER_SCHEDULE_SECONDS=0
CODEX_SCHEDULER_CODEX_ENABLED=true
CODEX_SCHEDULER_AUTOCHECK=true
CODEX_SCHEDULER_AUTOCOMMIT=false
CODEX_SCHEDULER_AUTOPUSH=false
CODEX_SCHEDULER_ALLOW_DIRTY=false
CODEX_SCHEDULER_COMMAND_TIMEOUT_SECONDS=1800
CODEX_SCHEDULER_COMMIT_MESSAGE=chore: apply scheduled codex improvement

ATHERNEX_CONTROL_PLANE_ROLE=local-control-plane
ATHERNEX_SCHEDULER_MODE=contract-only
ATHERNEX_LOCAL_CAPACITY_SLOTS=2
ATHERNEX_REMOTE_WAKE_THRESHOLD_SLOTS=3
ATHERNEX_IDLE_POWERDOWN_AFTER_SECONDS=900
AGENT_SYSTEM_ENV=local
AGENT_MAX_IN_FLIGHT=8
AGENT_RETRY_LIMIT=3
